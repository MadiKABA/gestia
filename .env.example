# Copier ce fichier en .env (dev local) ou .env.production (prod Docker) et compléter les valeurs.
# Validé au démarrage par src/lib/env.ts (Zod, fail-fast) — voir README.md pour la mise en place.

NODE_ENV=development

# --- Base de données -------------------------------------------------------
# Dev local : Postgres natif installé sur la machine (voir README "Installation locale").
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gestia_dev"

# Prod uniquement (docker-compose.prod.yml, dans .env.production) : identifiants
# du service `postgres` du compose, qui reconstruit DATABASE_URL lui-même à
# partir de ces 3 valeurs (la ligne DATABASE_URL ci-dessus est alors ignorée).
# POSTGRES_USER=gestia
# POSTGRES_PASSWORD=change-me-strong-random-password
# POSTGRES_DB=gestia

# --- BetterAuth --------------------------------------------------------------
# BETTER_AUTH_SECRET : chaîne aléatoire d'au moins 32 caractères (ex: `openssl rand -base64 32`)
BETTER_AUTH_SECRET="change-me-generate-a-random-32-char-secret"
BETTER_AUTH_URL="http://localhost:3000"
# Clé de chiffrement des closures de Server Actions (Next.js 16). Doit rester stable
# entre déploiements/instances. Générer avec `openssl rand -base64 32`.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="change-me-generate-a-random-32-char-key"

# --- SMS / OTP (Africa's Talking) -------------------------------------------
AFRICASTALKING_USERNAME="sandbox"
AFRICASTALKING_API_KEY="change-me"
AFRICASTALKING_SENDER_ID=""

# --- Upload logo boutique (Cloudinary) --------------------------------------
CLOUDINARY_CLOUD_NAME="change-me"
CLOUDINARY_API_KEY="change-me"
CLOUDINARY_API_SECRET="change-me"

# --- Public (exposées au client) --------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Gestia"
