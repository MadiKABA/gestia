// Schéma Prisma — Gestia V1 (cahier des charges §6)
// Prisma 7 : générateur "prisma-client" (client TS généré, plus de moteur Rust),
// connexion fournie via l'adapter driver dans src/infrastructure/prisma/client.ts.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  PATRON
  VENDEUR
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
}

enum PartyType {
  CLIENT
  SUPPLIER
  BOTH
}

enum TransactionType {
  CREANCE
  DETTE
}

enum TransactionStatus {
  EN_COURS
  PARTIELLE
  REGLEE
}

enum PaymentMethod {
  CASH
  WAVE
  ORANGE_MONEY
  AUTRE
}

enum PaymentDirection {
  IN
  OUT
}

enum CashMovementType {
  ENTREE
  SORTIE
}

enum OtpPurpose {
  REGISTRATION
  PIN_RESET
}

/**
 * Canal de délivrance de l'OTP — aussi le canal utilisé pour se connecter
 * (§4 : téléphone prioritaire, email un second identifiant possible).
 */
enum OtpChannel {
  PHONE
  EMAIL
}

/**
 * Devises supportées (`TenantSettings.currency`) — liste fermée, cohérente
 * avec `src/config/currencies.ts` (source de vérité applicative pour le
 * libellé affiché de chaque devise). Chaque tenant reste isolé sur la
 * sienne : ce n'est pas un système de conversion entre devises.
 */
enum Currency {
  FCFA
  GNF
}

/**
 * Type de commerce (`Tenant.businessType`) — liste fermée, cohérente avec
 * `src/domain/tenant/business-type.ts` (source de vérité applicative pour le
 * libellé, l'icône et la catégorie PRODUIT/SERVICE de chaque type).
 */
enum BusinessType {
  ALIMENTATION_GENERALE
  QUINCAILLERIE
  BOUCHERIE
  PRESSING
  VETEMENT
  TELEPHONE_ACCESSOIRES
  ELECTROMENAGER
  COSMETIQUE
  SALON_COIFFURE
  AUTRE
}

/**
 * Unité de mesure d'un `Product` — n'a de sens que pour `ProductType.PRODUIT`
 * (toujours `null` pour un `SERVICE`, cf. validation applicative dans
 * `src/domain/product/product.entity.ts`). Cohérente avec
 * `src/domain/product/product-unit.ts` (libellé + icône, source de vérité
 * applicative).
 */
enum ProductUnit {
  PIECE
  KILOGRAMME
  GRAMME
  LITRE
  MILLILITRE
  SAC
  CARTON
  DOUZAINE
  METRE
  PAQUET
  BOITE
  BOUTEILLE
  SACHET
  ROULEAU
  PAIRE
  LOT
  AUTRE
}

enum ProductType {
  PRODUIT
  SERVICE
}

// ---------------------------------------------------------------------------
// Admin — comptes du backoffice SaaS (hors périmètre tenant, auth email+mdp)
// ---------------------------------------------------------------------------

model Admin {
  id String @id @default(cuid())

  email        String @unique
  passwordHash String

  firstName String?
  lastName  String?

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

// ---------------------------------------------------------------------------
// Tenant — une boutique/entreprise cliente de Gestia
// ---------------------------------------------------------------------------

model Tenant {
  id      String  @id @default(cuid())
  name    String
  phone   String?
  address String?

  status       TenantStatus @default(TRIAL)
  trialEndsAt  DateTime?
  businessType BusinessType @default(ALIMENTATION_GENERALE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  parties           Party[]
  transactions      Transaction[]
  payments          Payment[]
  cashMovements     CashMovement[]
  settings          TenantSettings?
  auditLogs         AuditLog[]
  sequences         Sequence[]
  productCategories ProductCategory[]
  products          Product[]

  @@map("tenants")
}

// ---------------------------------------------------------------------------
// User — comptes qui se connectent (patron, vendeurs). Auth téléphone + PIN.
// ---------------------------------------------------------------------------

model User {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name    String
  phone   String  @unique
  pinHash String
  /**
   * Identifiant de connexion secondaire optionnel (§4) — le téléphone reste
   * l'identifiant prioritaire, mis en avant dans l'UI. Unique quand renseigné
   * (Postgres autorise plusieurs NULL sous une contrainte @unique).
   */
  email   String? @unique

  role           UserRole
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  active         Boolean   @default(true)
  /**
   * Posé une seule fois, quand un vendeur invité définit son PIN pour la
   * première fois (confirm-pin-reset.use-case.ts) — jamais réécrit ensuite,
   * y compris lors d'un reset PIN ultérieur. Permet de distinguer un vendeur
   * invité qui n'a pas encore terminé sa première connexion d'un vendeur
   * actif : le hash placeholder posé à l'invitation
   * (invite-vendeur.use-case.ts) n'est lui-même jamais relu, il ne peut pas
   * servir de signal fiable. Toujours `null` pour un patron (inscription
   * directe, pas de flux d'invitation).
   */
  firstLoginAt   DateTime?

  createdAt DateTime @default(now())

  // Champs requis par l'adapter better-auth (session/cookies) — la vérification
  // du PIN reste entièrement custom (Argon2 sur pinHash), better-auth ne gère
  // ici que l'émission/la validation de session (voir infrastructure/auth).
  emailVerified Boolean  @default(false)
  image         String?
  updatedAt     DateTime @updatedAt

  sessions Session[]

  createdTransactions  Transaction[]  @relation("TransactionCreator")
  createdPayments      Payment[]      @relation("PaymentCreator")
  createdCashMovements CashMovement[] @relation("CashMovementCreator")
  createdProducts      Product[]      @relation("ProductCreator")

  @@index([tenantId])
  @@map("users")
}

// ---------------------------------------------------------------------------
// Session — émise par better-auth après vérification custom du PIN
// ---------------------------------------------------------------------------

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("sessions")
}

// ---------------------------------------------------------------------------
// OtpCode — codes OTP SMS (Africa's Talking) pour inscription et reset PIN
// ---------------------------------------------------------------------------

model OtpCode {
  id         String     @id @default(cuid())
  /**
   * Téléphone (+221...) ou email selon `channel`.
   */
  identifier String
  channel    OtpChannel
  codeHash   String
  purpose    OtpPurpose
  expiresAt  DateTime
  consumedAt DateTime?
  /**
   * Nombre d'essais de code échoués — incrémenté atomiquement à chaque
   * vérification ratée (voir AuthRepository.incrementOtpAttempts), jamais
   * un read-then-write applicatif. Au-delà de MAX_OTP_ATTEMPTS (domain/auth/otp.ts),
   * l'OTP est invalidé (marqué consommé) : pas de déblocage automatique,
   * l'utilisateur doit redemander un nouveau code.
   */
  attempts   Int        @default(0)

  createdAt DateTime @default(now())

  @@index([identifier, channel, purpose])
  @@map("otp_codes")
}

// ---------------------------------------------------------------------------
// Sequence — compteurs annuels par tenant pour les références auto CR-/DT-
// ---------------------------------------------------------------------------

model Sequence {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  year Int

  creditCounter Int @default(0)
  debtCounter   Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, year])
  @@index([tenantId])
  @@map("sequences")
}

// ---------------------------------------------------------------------------
// Party — clients et fournisseurs d'un tenant
// ---------------------------------------------------------------------------

model Party {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name           String
  phone          String?
  whatsappNumber String?
  type           PartyType

  /**
   * Case "entreprise" optionnelle (cahier des charges §7) : companyName est
   * recommandé mais non bloquant quand isCompany est coché.
   */
  isCompany   Boolean @default(false)
  companyName String?
  contactName String?

  note String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  transactions  Transaction[]
  cashMovements CashMovement[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, updatedAt])
  @@map("parties")
}

// ---------------------------------------------------------------------------
// Transaction — créances (CREANCE) et dettes (DETTE)
// ---------------------------------------------------------------------------

model Transaction {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  reference String // CR-2026-00125 / DT-2026-00045
  partyId   String
  party     Party  @relation(fields: [partyId], references: [id], onDelete: Restrict)

  type        TransactionType
  description String
  quantity    Float?

  amount     Decimal @db.Decimal(14, 2)
  paidAmount Decimal @default(0) @db.Decimal(14, 2)

  dueDate DateTime?
  status  TransactionStatus @default(EN_COURS)

  createdById String
  createdBy   User   @relation("TransactionCreator", fields: [createdById], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  payments Payment[]

  @@unique([tenantId, reference])
  @@index([tenantId])
  @@index([tenantId, partyId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([tenantId, createdAt])
  @@map("transactions")
}

// ---------------------------------------------------------------------------
// Payment — règlements (partiels/totaux) d'une transaction
// ---------------------------------------------------------------------------

model Payment {
  id            String      @id @default(cuid())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  amount Decimal @db.Decimal(14, 2)

  method    PaymentMethod
  direction PaymentDirection

  note String?

  createdById String
  createdBy   User   @relation("PaymentCreator", fields: [createdById], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  cashMovement CashMovement?

  @@index([tenantId])
  @@index([tenantId, transactionId])
  @@index([tenantId, createdAt])
  @@map("payments")
}

// ---------------------------------------------------------------------------
// CashMovement — mouvements de caisse (manuels ou générés par un paiement cash)
// ---------------------------------------------------------------------------

model CashMovement {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type   CashMovementType
  amount Decimal          @db.Decimal(14, 2)

  reason String

  linkedPaymentId String?  @unique
  linkedPayment   Payment? @relation(fields: [linkedPaymentId], references: [id], onDelete: SetNull)

  // Vente au comptant uniquement : client et mode de paiement optionnels,
  // restent `null` pour un mouvement de caisse manuel classique.
  partyId String?
  party   Party?         @relation(fields: [partyId], references: [id], onDelete: SetNull)
  method  PaymentMethod?

  createdById String
  createdBy   User   @relation("CashMovementCreator", fields: [createdById], references: [id])

  date DateTime @default(now())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
  @@index([tenantId, date])
  @@index([tenantId, createdAt])
  @@index([tenantId, partyId])
  @@map("cash_movements")
}

// ---------------------------------------------------------------------------
// TenantSettings — paramètres + theming du commerce (1-1 avec Tenant)
// ---------------------------------------------------------------------------

model TenantSettings {
  tenantId String @id
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  currency                       Currency @default(FCFA)
  reminderDays                   Int      @default(7)
  whatsappTemplate               String?
  whatsappReceiptPartialTemplate String?
  whatsappReceiptFinalTemplate   String?

  // Theming : brandColor doit être un des presets validés (contrôlé côté application, pas en DB)
  brandColor  String? @default("#0F2A4A")
  logoUrl     String?
  displayName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenant_settings")
}

// ---------------------------------------------------------------------------
// AuditLog — traçabilité systématique de toute mutation métier
// ---------------------------------------------------------------------------

model AuditLog {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String

  action   String
  entity   String
  entityId String
  oldData  Json?
  newData  Json?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, entity, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// ProductCategory / Product — catalogue produits (V1, cf. CLAUDE.md Scope V1 :
// le champ trackStock/stockQuantity reste purement informatif, la
// décrémentation automatique à la vente est un chantier séparé, hors V1).
// ---------------------------------------------------------------------------

model ProductCategory {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name String

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("product_categories")
}

model Product {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String?
  type        ProductType
  price       Decimal     @db.Decimal(14, 2)

  /**
   * `unit`/`stockQuantity` n'ont de sens que si `type = PRODUIT` — toujours
   * `null` pour un `SERVICE` (cf. validate-product-input, appliqué en amont
   * de la base, pas seulement ici).
   */
  unit          ProductUnit?
  trackStock    Boolean      @default(false)
  stockQuantity Decimal?     @db.Decimal(14, 2)

  barcode  String?
  photoUrl String?

  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("ProductCreator", fields: [createdById], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([tenantId, barcode])
  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@map("products")
}
