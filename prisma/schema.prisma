// Schéma Prisma — Gestia V1 (cahier des charges §6)
// Prisma 7 : générateur "prisma-client" (client TS généré, plus de moteur Rust),
// connexion fournie via l'adapter driver dans src/infrastructure/prisma/client.ts.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  PATRON
  VENDEUR
}

enum PartyType {
  CLIENT
  SUPPLIER
  BOTH
}

enum TransactionType {
  CREANCE
  DETTE
}

enum TransactionStatus {
  EN_COURS
  PARTIELLE
  REGLEE
}

enum PaymentMethod {
  CASH
  WAVE
  ORANGE_MONEY
  AUTRE
}

enum PaymentDirection {
  IN
  OUT
}

enum CashMovementType {
  ENTREE
  SORTIE
}

enum OtpPurpose {
  REGISTRATION
  PIN_RESET
}

// ---------------------------------------------------------------------------
// Tenant — une boutique/entreprise cliente de Gestia
// ---------------------------------------------------------------------------

model Tenant {
  id      String  @id @default(cuid())
  name    String
  phone   String?
  address String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  parties       Party[]
  transactions  Transaction[]
  payments      Payment[]
  cashMovements CashMovement[]
  settings      TenantSettings?
  auditLogs     AuditLog[]
  sequences     Sequence[]

  @@map("tenants")
}

// ---------------------------------------------------------------------------
// User — comptes qui se connectent (patron, vendeurs). Auth téléphone + PIN.
// ---------------------------------------------------------------------------

model User {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name    String
  phone   String  @unique
  pinHash String
  email   String?

  role           UserRole
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  active         Boolean   @default(true)

  createdAt DateTime @default(now())

  // Champs requis par l'adapter better-auth (session/cookies) — la vérification
  // du PIN reste entièrement custom (Argon2 sur pinHash), better-auth ne gère
  // ici que l'émission/la validation de session (voir infrastructure/auth).
  emailVerified Boolean  @default(false)
  image         String?
  updatedAt     DateTime @updatedAt

  sessions Session[]

  createdTransactions  Transaction[]  @relation("TransactionCreator")
  createdPayments      Payment[]      @relation("PaymentCreator")
  createdCashMovements CashMovement[] @relation("CashMovementCreator")

  @@index([tenantId])
  @@map("users")
}

// ---------------------------------------------------------------------------
// Session — émise par better-auth après vérification custom du PIN
// ---------------------------------------------------------------------------

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("sessions")
}

// ---------------------------------------------------------------------------
// OtpCode — codes OTP SMS (Africa's Talking) pour inscription et reset PIN
// ---------------------------------------------------------------------------

model OtpCode {
  id         String     @id @default(cuid())
  phone      String
  codeHash   String
  purpose    OtpPurpose
  expiresAt  DateTime
  consumedAt DateTime?

  createdAt DateTime @default(now())

  @@index([phone, purpose])
  @@map("otp_codes")
}

// ---------------------------------------------------------------------------
// Sequence — compteurs annuels par tenant pour les références auto CR-/DT-
// ---------------------------------------------------------------------------

model Sequence {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  year Int

  creditCounter Int @default(0)
  debtCounter   Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, year])
  @@index([tenantId])
  @@map("sequences")
}

// ---------------------------------------------------------------------------
// Party — clients et fournisseurs d'un tenant
// ---------------------------------------------------------------------------

model Party {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name           String
  phone          String?
  whatsappNumber String?
  type           PartyType

  note String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  transactions Transaction[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@map("parties")
}

// ---------------------------------------------------------------------------
// Transaction — créances (CREANCE) et dettes (DETTE)
// ---------------------------------------------------------------------------

model Transaction {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  reference String // CR-2026-00125 / DT-2026-00045
  partyId   String
  party     Party  @relation(fields: [partyId], references: [id], onDelete: Restrict)

  type        TransactionType
  description String
  quantity    Float?

  amount     Decimal @db.Decimal(14, 2)
  paidAmount Decimal @default(0) @db.Decimal(14, 2)

  dueDate DateTime?
  status  TransactionStatus @default(EN_COURS)

  createdById String
  createdBy   User   @relation("TransactionCreator", fields: [createdById], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  payments Payment[]

  @@unique([tenantId, reference])
  @@index([tenantId])
  @@index([tenantId, partyId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([tenantId, createdAt])
  @@map("transactions")
}

// ---------------------------------------------------------------------------
// Payment — règlements (partiels/totaux) d'une transaction
// ---------------------------------------------------------------------------

model Payment {
  id            String      @id @default(cuid())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  amount Decimal @db.Decimal(14, 2)

  method    PaymentMethod
  direction PaymentDirection

  note String?

  createdById String
  createdBy   User   @relation("PaymentCreator", fields: [createdById], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  cashMovement CashMovement?

  @@index([tenantId])
  @@index([tenantId, transactionId])
  @@index([tenantId, createdAt])
  @@map("payments")
}

// ---------------------------------------------------------------------------
// CashMovement — mouvements de caisse (manuels ou générés par un paiement cash)
// ---------------------------------------------------------------------------

model CashMovement {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type   CashMovementType
  amount Decimal          @db.Decimal(14, 2)

  reason String

  linkedPaymentId String?  @unique
  linkedPayment   Payment? @relation(fields: [linkedPaymentId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("CashMovementCreator", fields: [createdById], references: [id])

  date DateTime @default(now())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
  @@index([tenantId, date])
  @@index([tenantId, createdAt])
  @@map("cash_movements")
}

// ---------------------------------------------------------------------------
// TenantSettings — paramètres + theming du commerce (1-1 avec Tenant)
// ---------------------------------------------------------------------------

model TenantSettings {
  tenantId String @id
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  currency         String  @default("FCFA")
  reminderDays     Int     @default(7)
  whatsappTemplate String?

  // Theming : brandColor doit être un des presets validés (contrôlé côté application, pas en DB)
  brandColor  String? @default("#0F2A4A")
  logoUrl     String?
  displayName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenant_settings")
}

// ---------------------------------------------------------------------------
// AuditLog — traçabilité systématique de toute mutation métier
// ---------------------------------------------------------------------------

model AuditLog {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String

  action   String
  entity   String
  entityId String
  oldData  Json?
  newData  Json?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, entity, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}
